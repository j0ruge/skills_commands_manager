# Caddyfile — generated by dev.script skill
# Reverse-proxies HTTPS-on-LAN to the dev servers running on the host.
# Default port mapping (HTTPS public ↔ HTTP internal):
#   <<WEB_PORT>>  ↔ 5173 (Vite)
#   <<API_PORT>>  ↔ 3000 (Express/Nest)
#   <<IDP_PORT>>  ↔ 8080 (Zitadel — adjust if missing)

{
  auto_https off       # certs come from mkcert; do not attempt Let's Encrypt
  admin off            # don't open the admin endpoint on :2019
}

<<EXTERNAL_DOMAIN>>:<<WEB_PORT>> {
  tls /certs/dev.pem /certs/dev.key
  reverse_proxy <<UPSTREAM_HOST>>:5173
}

<<EXTERNAL_DOMAIN>>:<<API_PORT>> {
  tls /certs/dev.pem /certs/dev.key
  reverse_proxy <<UPSTREAM_HOST>>:3000
}

# <<#IF HAS_IDP>>
<<EXTERNAL_DOMAIN>>:<<IDP_PORT>> {
  tls /certs/dev.pem /certs/dev.key
  reverse_proxy <<UPSTREAM_HOST>>:8080
}
# <<#END>>

# Substitution legend:
#   <<EXTERNAL_DOMAIN>>  e.g. 192.168.0.42.sslip.io
#   <<WEB_PORT>>         e.g. 5443
#   <<API_PORT>>         e.g. 3443
#   <<IDP_PORT>>         e.g. 8443
#   <<UPSTREAM_HOST>>    "localhost" (Linux network_mode: host)
#                        or "host.docker.internal" (macOS/Windows + extra_hosts)
