#Requires -Version 5.1
<#
.SYNOPSIS
  <<PROJECT_NAME>> — local dev launcher (PowerShell port)
.DESCRIPTION
  <<ONE_LINE_PURPOSE>>
.NOTES
  Generated by the dev.script skill. Companion to dev.sh — same flags, same
  semantics, idiomatic PowerShell primitives. Tested on PowerShell 7+;
  PowerShell 5.1 (legacy Windows console) needs the VT-mode shim emitted in
  the preamble.
#>

[CmdletBinding()] param(
  [string]$DevHost = "",
  [switch]$NoLan,
  [switch]$NoHttps,
  [switch]$Reset,
  [switch]$Down
)

$ErrorActionPreference = 'Stop'
Set-StrictMode -Version 3.0

$SCRIPT_DIR = Split-Path -LiteralPath $MyInvocation.MyCommand.Path -Parent
Set-Location -LiteralPath $SCRIPT_DIR

# ---- VT-mode shim for PS 5.1 (so ANSI prefixes render in legacy conhost) ----
if ($PSVersionTable.PSVersion.Major -lt 7) {
  try {
    $sig = '[DllImport("kernel32.dll")] public static extern bool SetConsoleMode(IntPtr h, uint m);
            [DllImport("kernel32.dll")] public static extern IntPtr GetStdHandle(int n);'
    Add-Type -MemberDefinition $sig -Name VT -Namespace WinAPI -ErrorAction SilentlyContinue
    [WinAPI.VT]::SetConsoleMode([WinAPI.VT]::GetStdHandle(-11), 0x0007) | Out-Null
  } catch { }
}

# ---- color logging ----------------------------------------------------------
function Write-Info  { param($M) Write-Host "[INFO] $M"  -ForegroundColor Green }
function Write-WarnLog { param($M) Write-Host "[WARN] $M"  -ForegroundColor Yellow }
function Write-ErrorLog{ param($M) Write-Host "[ERROR] $M" -ForegroundColor Red }
function Write-Step  { param($M) Write-Host "`n==> $M" -ForegroundColor Blue }

$LanMode = -not $NoLan
$TlsMode = -not ($NoHttps -or $NoLan)   # <<#IF NO_TLS>>: $TlsMode = $false

# ---- LAN host detection -----------------------------------------------------
function Get-LanIp {
  if ($IsLinux -or $IsMacOS) {
    try { return (& hostname -I 2>$null).Trim().Split()[0] } catch { }
    return $null
  }
  try {
    $r = Find-NetRoute -RemoteIPAddress 1.1.1.1 -ErrorAction Stop | Select-Object -First 1
    if ($r -and $r.IPAddress) { return $r.IPAddress }
  } catch { }
  $ip = Get-NetIPAddress -AddressFamily IPv4 -ErrorAction SilentlyContinue |
        Where-Object { $_.IPAddress -notmatch '^(127\.|169\.254\.)' } |
        Select-Object -ExpandProperty IPAddress -First 1
  return $ip
}

if ($DevHost) { $Host_ = $DevHost }
elseif ($LanMode) {
  $Host_ = Get-LanIp
  if (-not $Host_) { Write-WarnLog "Could not detect LAN IP — falling back to 127.0.0.1"; $Host_ = '127.0.0.1'; $LanMode = $false; $TlsMode = $false }
} else { $Host_ = '127.0.0.1' }

if ($Host_ -match '^\d+\.\d+\.\d+\.\d+$') { $ExternalDomain = "$Host_.sslip.io" } else { $ExternalDomain = $Host_ }

# <<#IF HAS_TLS>>
if ($TlsMode) { $Scheme = 'https'; $WebPort = 5443; $ApiPort = 3443; $IdpPort = 8443 }
else { $Scheme = 'http';  $WebPort = 5173; $ApiPort = 3000; $IdpPort = 8080 }
# <<#ELSE>>
# $Scheme = 'http'; $WebPort = 5173; $ApiPort = 3000
# <<#END>>

$WebBase = "${Scheme}://${ExternalDomain}:${WebPort}"
$ApiBase = "${Scheme}://${ExternalDomain}:${ApiPort}"
# <<#IF HAS_IDP>>
$ZitadelBase  = "${Scheme}://${ExternalDomain}:${IdpPort}"
$ExternalFull = $ZitadelBase
# <<#END>>

Write-Info "Host=$Host_  External=$ExternalDomain  Scheme=$Scheme  LAN=$LanMode  TLS=$TlsMode"

# ---- file paths -------------------------------------------------------------
$StateFile      = Join-Path $SCRIPT_DIR '.dev.script.state'
$RootEnvLocal   = Join-Path $SCRIPT_DIR '.env.local'
$BackendEnv     = Join-Path $SCRIPT_DIR '<<BACKEND_ENV_PATH>>'
$ComposeBase    = Join-Path $SCRIPT_DIR '<<COMPOSE_BASE>>'
# <<#IF HAS_IDP>>
$ComposeIdp     = Join-Path $SCRIPT_DIR '<<COMPOSE_IDP>>'
$ComposeIdpOver = Join-Path $SCRIPT_DIR '<<COMPOSE_IDP_OVERRIDE>>'
$CertsDir       = Join-Path $SCRIPT_DIR 'infra/certs'
$CaddyDir       = Join-Path $SCRIPT_DIR 'infra/caddy'
$ViteHttpsCfg   = Join-Path $SCRIPT_DIR '.vite.config.lan.ts'
# <<#END>>

# <<#IF HAS_IDP>>
# ---- pre-flight: drift detection -------------------------------------------
$PrevExternal = ''
if (Test-Path -LiteralPath $StateFile) {
  $line = (Get-Content -LiteralPath $StateFile | Where-Object { $_ -match '^EXTERNAL_FULL=' } | Select-Object -First 1)
  if ($line) { $PrevExternal = $line -replace '^EXTERNAL_FULL=','' }
}
$HasVolume = $null
try { $HasVolume = (& docker volume ls --format '{{.Name}}') | Where-Object { $_ -match '<<IDP_VOLUME_PATTERN>>' } | Select-Object -First 1 } catch { }

if ($Reset) {
  Write-WarnLog "--Reset: dropping IdP and volume…"
  & docker compose -f $ComposeIdp down -v 2>&1 | Out-Null
  $PrevExternal = ''
} elseif ($PrevExternal -and $PrevExternal -ne $ExternalFull -and $HasVolume) {
  Write-ErrorLog "IdP was initialized with $PrevExternal; switching to $ExternalFull requires reset."
  Write-ErrorLog "Run: pwsh ./dev.ps1 -Reset"
  exit 1
}
# <<#END>>

# <<#IF HAS_TLS>>
# ---- TLS: mkcert + Caddy ----------------------------------------------------
$MkcertCaroot = $null
if ($TlsMode) {
  if (-not (Get-Command mkcert -ErrorAction SilentlyContinue)) {
    Write-ErrorLog "mkcert not found. Install: 'winget install FiloSottile.mkcert' (or run with -NoHttps)"; exit 1
  }
  $MkcertCaroot = (& mkcert -CAROOT).Trim()
  if (-not (Test-Path -LiteralPath (Join-Path $MkcertCaroot 'rootCA.pem'))) {
    Write-Step "Installing mkcert root CA (may prompt for elevation)…"
    & mkcert -install
  }

  New-Item -ItemType Directory -Force -Path $CertsDir, $CaddyDir | Out-Null
  $CertFile = Join-Path $CertsDir 'dev.pem'
  $KeyFile  = Join-Path $CertsDir 'dev.key'
  $NamesFile = Join-Path $CertsDir '.names'
  $CurrentNames = "$ExternalDomain $Host_ localhost 127.0.0.1"
  $PrevNames = if (Test-Path -LiteralPath $NamesFile) { Get-Content -LiteralPath $NamesFile -Raw } else { '' }
  if (-not (Test-Path -LiteralPath $CertFile) -or -not (Test-Path -LiteralPath $KeyFile) -or $PrevNames.Trim() -ne $CurrentNames) {
    Write-Step "Issuing mkcert leaf for: $CurrentNames"
    & mkcert -cert-file $CertFile -key-file $KeyFile $ExternalDomain $Host_ localhost 127.0.0.1
    Set-Content -LiteralPath $NamesFile -Value $CurrentNames
  }

  # Make rootCA available for LAN clients
  $publicCa = Join-Path $SCRIPT_DIR '<<PUBLIC_DIR>>/dev-rootCA.pem'
  Copy-Item -LiteralPath (Join-Path $MkcertCaroot 'rootCA.pem') -Destination $publicCa -Force -ErrorAction SilentlyContinue

  $caddyfile = @"
{
  auto_https off
  admin off
}

${ExternalDomain}:${WebPort} {
  tls /certs/dev.pem /certs/dev.key
  reverse_proxy host.docker.internal:5173
}

${ExternalDomain}:${ApiPort} {
  tls /certs/dev.pem /certs/dev.key
  reverse_proxy host.docker.internal:3000
}

${ExternalDomain}:${IdpPort} {
  tls /certs/dev.pem /certs/dev.key
  reverse_proxy host.docker.internal:8080
}
"@
  Set-Content -LiteralPath (Join-Path $CaddyDir 'Caddyfile') -Value $caddyfile

  $viteWrap = @'
import base from "./vite.config";
import { mergeConfig } from "vite";
export default mergeConfig(base, {
  server: {
    allowedHosts: true,
    hmr: { clientPort: 5443, protocol: "wss", host: process.env.DEV_SH_EXTERNAL ?? "localhost" },
  },
});
'@
  Set-Content -LiteralPath $ViteHttpsCfg -Value $viteWrap
}
# <<#END>>

# ---- envs -------------------------------------------------------------------
function Set-EnvKv {
  param([string]$File, [string]$Key, [string]$Value)
  if (-not (Test-Path -LiteralPath $File)) { New-Item -ItemType File -Path $File | Out-Null }
  $content = Get-Content -LiteralPath $File -Raw -ErrorAction SilentlyContinue
  if ($null -eq $content) { $content = "" }
  $pattern = "(?m)^${Key}=.*$"
  $new = if ($content -match $pattern) {
    [regex]::Replace($content, $pattern, "${Key}=${Value}")
  } else {
    $content.TrimEnd("`r","`n") + "`n${Key}=${Value}`n"
  }
  Set-Content -LiteralPath $File -Value $new -NoNewline:$false
}

Write-Step "Synthesizing envs…"
$envLocal = @"
VITE_API_BASE_URL=${ApiBase}/api
"@
# <<#IF HAS_OIDC>>
$envLocal += @"

VITE_OIDC_AUTHORITY=${ZitadelBase}
VITE_OIDC_CLIENT_ID=
VITE_OIDC_REDIRECT_URI=${WebBase}/auth/callback
VITE_OIDC_POST_LOGOUT_REDIRECT_URI=${WebBase}/login
VITE_OIDC_SILENT_REDIRECT_URI=${WebBase}/silent-renew
VITE_OIDC_SCOPE=openid profile email
"@
# <<#END>>
Set-Content -LiteralPath $RootEnvLocal -Value $envLocal

# <<#IF HAS_OIDC>>
Set-EnvKv -File $BackendEnv -Key 'AUTH_ISSUER'   -Value $ZitadelBase
Set-EnvKv -File $BackendEnv -Key 'AUTH_JWKS_URL' -Value "${ZitadelBase}/oauth/v2/keys"
# <<#END>>
Set-EnvKv -File $BackendEnv -Key 'CORS_ORIGINS' -Value $WebBase
Set-EnvKv -File $BackendEnv -Key 'RATE_LIMIT_PER_MINUTE' -Value '0'

# <<#IF HAS_IDP>>
$secureBool = if ($TlsMode) { 'true' } else { 'false' }
$override = @"
services:
  zitadel-init:
    environment:
      ZITADEL_EXTERNALDOMAIN: $ExternalDomain
      ZITADEL_EXTERNALPORT: $IdpPort
      ZITADEL_EXTERNALSECURE: $secureBool
  zitadel:
    environment:
      ZITADEL_EXTERNALDOMAIN: $ExternalDomain
      ZITADEL_EXTERNALPORT: $IdpPort
      ZITADEL_EXTERNALSECURE: $secureBool
"@
if ($TlsMode) {
  $override += @"

    command: >-
      start-from-init
      --masterkey `${ZITADEL_MASTERKEY:?required in infra/docker/.env}
      --tlsMode external

  caddy:
    image: caddy:2-alpine
    restart: unless-stopped
    ports: ["${WebPort}:${WebPort}", "${ApiPort}:${ApiPort}", "${IdpPort}:${IdpPort}"]
    extra_hosts: ["host.docker.internal:host-gateway"]
    depends_on: { zitadel: { condition: service_healthy } }
    volumes:
      - $CaddyDir/Caddyfile:/etc/caddy/Caddyfile:ro
      - ${CertsDir}:/certs:ro
"@
}
Set-Content -LiteralPath $ComposeIdpOver -Value $override
# <<#END>>

Write-Info "Envs synthesized"

# ---- containers ------------------------------------------------------------
Write-Step "Postgres up…"
& docker compose -f $ComposeBase up -d postgres
Write-Step "Wait Postgres…"
$ok = $false
for ($i = 1; $i -le 30; $i++) {
  $null = & docker compose -f $ComposeBase exec -T postgres pg_isready -U <<DB_USER>> 2>&1
  if ($LASTEXITCODE -eq 0) { Write-Info "Postgres ready"; $ok = $true; break }
  Start-Sleep -Seconds 1
}
if (-not $ok) { Write-ErrorLog "Postgres did not become ready"; exit 1 }

# <<#IF HAS_IDP>>
Write-Step "IdP up…"
& docker compose -f $ComposeIdp -f $ComposeIdpOver up -d <<IDP_CORE_SERVICES>>
if ($TlsMode) { & docker compose -f $ComposeIdp -f $ComposeIdpOver up -d caddy }

Write-Step "Wait IdP…"
$caCert = if ($TlsMode) { Join-Path $MkcertCaroot 'rootCA.pem' } else { $null }
$ok = $false
for ($i = 1; $i -le 60; $i++) {
  $null = if ($caCert) {
    & curl --silent --fail --cacert $caCert "$ZitadelBase<<IDP_HEALTH_PATH>>" 2>&1
  } else {
    & curl --silent --fail "$ZitadelBase<<IDP_HEALTH_PATH>>" 2>&1
  }
  if ($LASTEXITCODE -eq 0) { Write-Info "IdP ready"; $ok = $true; break }
  Start-Sleep -Seconds 2
}
if (-not $ok) { Write-ErrorLog "IdP not ready at $ZitadelBase"; exit 1 }
# <<#END>>

# <<#IF HAS_BOOTSTRAP>>
$BootstrapOut = Join-Path $SCRIPT_DIR '<<BOOTSTRAP_OUTPUT_PATH>>'
$skipBootstrap = ($PrevExternal -and $PrevExternal -eq $ExternalFull -and (Test-Path -LiteralPath $BootstrapOut))
if ($skipBootstrap) {
  Write-Step "Bootstrap — skipping (already up to date for $ExternalFull)"
} else {
  Write-Step "Bootstrap…"
  if ($TlsMode) { $env:NODE_EXTRA_CA_CERTS = (Join-Path $MkcertCaroot 'rootCA.pem') }
  <<BOOTSTRAP_COMMAND_PS>>
  if (-not (Test-Path -LiteralPath $BootstrapOut)) {
    Write-ErrorLog "Bootstrap did not produce $BootstrapOut"; exit 1
  }
}

if (Test-Path -LiteralPath $BootstrapOut) {
  $bs = Get-Content -LiteralPath $BootstrapOut -Raw | ConvertFrom-Json
  if ($bs.clientId)  { Set-EnvKv -File $RootEnvLocal -Key 'VITE_OIDC_CLIENT_ID' -Value $bs.clientId; Write-Info "VITE_OIDC_CLIENT_ID=$($bs.clientId)" }
  if ($bs.projectId) { Set-EnvKv -File $BackendEnv   -Key 'AUTH_AUDIENCE'      -Value $bs.projectId; Write-Info "AUTH_AUDIENCE=$($bs.projectId)" }
}
# <<#END>>

# Persist state
@"
EXTERNAL_FULL=$($ExternalFull ?? '')
HOST=$Host_
TLS=$TlsMode
"@ | Set-Content -LiteralPath $StateFile

# ---- port reclaim ----------------------------------------------------------
function Stop-PortHolder {
  param([int]$Port)
  if ($IsWindows -or [Environment]::OSVersion.Platform -eq 'Win32NT') {
    $owners = Get-NetTCPConnection -LocalPort $Port -State Listen -ErrorAction SilentlyContinue
    foreach ($o in $owners) {
      Write-WarnLog "Port $Port held by PID $($o.OwningProcess) — killing"
      Stop-Process -Id $o.OwningProcess -Force -ErrorAction SilentlyContinue
    }
  } else {
    $pids = & fuser "$Port/tcp" 2>$null | ForEach-Object { ($_ -split '\s+') } | Where-Object { $_ -match '^\d+$' } | Sort-Object -Unique
    if (-not $pids) { $pids = & lsof "-tiTCP:$Port" "-sTCP:LISTEN" 2>$null }
    foreach ($p in $pids) { Write-WarnLog "Port $Port held by PID $p — killing"; & kill -9 $p 2>$null }
  }
}
Write-Step "Free ports 3000 / 5173…"
Stop-PortHolder -Port 3000; Stop-PortHolder -Port 5173

# ---- dev servers + cleanup -------------------------------------------------
$Global:DevJobs = @()
function Stop-DevJobs {
  foreach ($j in $Global:DevJobs) {
    try { Stop-Job -Job $j -ErrorAction SilentlyContinue; Remove-Job -Job $j -Force -ErrorAction SilentlyContinue } catch { }
  }
}
Register-EngineEvent -SourceIdentifier PowerShell.Exiting -SupportEvent -Action { Stop-DevJobs } | Out-Null

try {
  Write-Step "Backend up…"
  $backendCmd = {
    param($Dir, $ExtraCa)
    Set-Location -LiteralPath $Dir
    if ($ExtraCa) { $env:NODE_EXTRA_CA_CERTS = $ExtraCa }
    <<BACKEND_DEV_CMD_PS>>
  }
  $extraCa = if ($TlsMode) { Join-Path $MkcertCaroot 'rootCA.pem' } else { $null }
  $backendJob = Start-Job -Name 'BACKEND' -ScriptBlock $backendCmd -ArgumentList (Join-Path $SCRIPT_DIR '<<BACKEND_DIR>>'), $extraCa
  $Global:DevJobs += $backendJob

  Write-Step "Frontend up…"
  $webCmd = {
    param($Dir, $External, $WithTls, $ConfigPath)
    Set-Location -LiteralPath $Dir
    $env:DEV_SH_EXTERNAL = $External
    if ($WithTls) {
      <<FRONTEND_DEV_CMD_PS>> --config $ConfigPath --host 0.0.0.0 --port 5173 --strictPort
    } else {
      <<FRONTEND_DEV_CMD_PS>> --host 0.0.0.0 --port 5173 --strictPort
    }
  }
  $webJob = Start-Job -Name 'WEB' -ScriptBlock $webCmd -ArgumentList $SCRIPT_DIR, $ExternalDomain, $TlsMode, $ViteHttpsCfg
  $Global:DevJobs += $webJob

  # ---- summary -------------------------------------------------------------
  Start-Sleep -Seconds 2
  Write-Host ""
  Write-Host "=============================================" -ForegroundColor Green
  Write-Host "  <<PROJECT_NAME>> — dev mode"               -ForegroundColor Green
  Write-Host "=============================================" -ForegroundColor Green
  Write-Host ""
  Write-Host "  Frontend  → $WebBase"   -ForegroundColor Blue
  Write-Host "  Backend   → $ApiBase/api" -ForegroundColor Green
  # <<#IF HAS_IDP>>
  Write-Host "  IdP       → $ZitadelBase" -ForegroundColor Magenta
  # <<#END>>
  Write-Host ""
  if ($LanMode) { Write-Host "  LAN sharing — clients open $WebBase" -ForegroundColor Yellow }
  if ($TlsMode) {
    Write-Host "  HTTPS via mkcert — clients must trust the local rootCA:" -ForegroundColor Yellow
    Write-Host "    on dev host: $(Join-Path $MkcertCaroot 'rootCA.pem')"
    Write-Host "    download:    $WebBase/dev-rootCA.pem"
  }
  Write-Host "  Ctrl+C stops dev servers (containers persist; -Down tears down)."
  Write-Host "============================================="  -ForegroundColor Green
  Write-Host ""

  # Stream both jobs' output until one exits
  while ($Global:DevJobs.State -contains 'Running') {
    Receive-Job -Job $Global:DevJobs -Keep | ForEach-Object { Write-Host $_ }
    Start-Sleep -Milliseconds 500
  }
}
finally {
  Stop-DevJobs
  if ($Down) {
    Write-WarnLog "-Down: tearing down containers"
    # <<#IF HAS_IDP>>
    & docker compose -f $ComposeIdp -f $ComposeIdpOver down 2>&1 | Out-Null
    # <<#END>>
    & docker compose -f $ComposeBase down 2>&1 | Out-Null
  }
  Write-Info "Stopped."
}
