#!/usr/bin/env bash
set -euo pipefail

# =============================================================================
# <<PROJECT_NAME>> — local dev launcher
#
# <<ONE_LINE_PURPOSE>>
#
# Generated by the dev.script skill. Re-running this generator with new stack
# detections will refresh the script. Manual edits below the marker are kept.
# =============================================================================

# ---- substitution placeholders (the skill replaces these per project) ------
# <<PROJECT_NAME>>          e.g. "battery-lifecycle"
# <<COMPOSE_BASE>>          e.g. "docker-compose.yml"
# <<COMPOSE_IDP>>           e.g. "infra/docker/docker-compose.zitadel.yml"  (omit block if no IdP)
# <<DB_USER>>               e.g. "jrc" (Postgres user for pg_isready)
# <<EXTERNAL_PORTS>>        Web/API/IdP port triple — 5173/3000/8080 plain, 5443/3443/8443 TLS

# ---- portable script-dir resolution ----------------------------------------
resolve_script_dir() {
  local src="${BASH_SOURCE[0]}"
  if command -v realpath >/dev/null 2>&1; then dirname "$(realpath "$src")"
  elif readlink -f "$src" >/dev/null 2>&1;     then dirname "$(readlink -f "$src")"
  else (cd "$(dirname "$src")" && pwd -P); fi
}
DIR="$(resolve_script_dir)"
cd "$DIR"

# ---- color logging ---------------------------------------------------------
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; MAGENTA='\033[0;35m'; NC='\033[0m'
log_info()  { echo -e "${GREEN}[INFO]${NC} $*"; }
log_warn()  { echo -e "${YELLOW}[WARN]${NC} $*"; }
log_error() { echo -e "${RED}[ERROR]${NC} $*"; }
log_step()  { echo -e "\n${BLUE}==>${NC} $*"; }

# ---- args ------------------------------------------------------------------
HOST_OVERRIDE=""
LAN_MODE=true
TLS_MODE=true            # <<#IF NO_TLS>>: change default to false
RESET=false
DOWN_ON_EXIT=false

usage() { cat <<EOF
Usage: ./dev.sh [OPTIONS]
  --host <ip>      override LAN IP detection
  --no-lan         localhost only (HTTP)
  --no-https       skip TLS termination (LAN OIDC will fail outside localhost)
  --reset          drop volatile state (e.g., IdP volume) before booting
  --down           tear down containers when this script exits
  -h, --help       show this help
EOF
}
while [[ $# -gt 0 ]]; do case "$1" in
  --host)     HOST_OVERRIDE="$2"; shift 2 ;;
  --no-lan)   LAN_MODE=false; TLS_MODE=false; shift ;;
  --no-https) TLS_MODE=false; shift ;;
  --reset)    RESET=true; shift ;;
  --down)     DOWN_ON_EXIT=true; shift ;;
  -h|--help)  usage; exit 0 ;;
  *) log_error "Unknown option: $1"; usage; exit 1 ;;
esac; done

# ---- LAN host resolution ---------------------------------------------------
detect_lan_ip() {
  local ip=""
  if command -v hostname >/dev/null 2>&1; then ip="$(hostname -I 2>/dev/null | awk '{print $1}')"; fi
  if [[ -z "$ip" ]] && command -v ip >/dev/null 2>&1; then
    ip="$(ip -4 -o route get 1.1.1.1 2>/dev/null | awk '{for(i=1;i<=NF;i++) if($i=="src"){print $(i+1); exit}}')"
  fi
  if [[ -z "$ip" ]] && command -v ipconfig >/dev/null 2>&1; then
    ip="$(ipconfig getifaddr en0 2>/dev/null)"; [[ -z "$ip" ]] && ip="$(ipconfig getifaddr en1 2>/dev/null)"
  fi
  echo "$ip"
}
if [[ -n "$HOST_OVERRIDE" ]]; then HOST="$HOST_OVERRIDE"
elif $LAN_MODE; then
  HOST="$(detect_lan_ip)"
  if [[ -z "$HOST" ]]; then log_warn "Could not detect LAN IP — falling back to 127.0.0.1"; HOST="127.0.0.1"; LAN_MODE=false; TLS_MODE=false; fi
else HOST="127.0.0.1"; fi

if [[ "$HOST" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then EXTERNAL_DOMAIN="${HOST}.sslip.io"
else EXTERNAL_DOMAIN="$HOST"; fi

# <<#IF HAS_TLS>>
if $TLS_MODE; then
  SCHEME="https"; WEB_PORT=5443; API_PORT=3443; IDP_PORT=8443
else
  SCHEME="http";  WEB_PORT=5173; API_PORT=3000; IDP_PORT=8080
fi
# <<#ELSE>>
# SCHEME="http"; WEB_PORT=5173; API_PORT=3000
# <<#END>>

WEB_BASE="${SCHEME}://${EXTERNAL_DOMAIN}:${WEB_PORT}"
API_BASE="${SCHEME}://${EXTERNAL_DOMAIN}:${API_PORT}"
# <<#IF HAS_IDP>>
ZITADEL_BASE="${SCHEME}://${EXTERNAL_DOMAIN}:${IDP_PORT}"
EXTERNAL_FULL="$ZITADEL_BASE"     # identity for state-drift detection
# <<#END>>

log_info "Host=${HOST}  External=${EXTERNAL_DOMAIN}  Scheme=${SCHEME}  LAN=${LAN_MODE}  TLS=${TLS_MODE}"

# ---- file paths ------------------------------------------------------------
STATE_FILE="${DIR}/.dev.script.state"
ROOT_ENV_LOCAL="${DIR}/.env.local"
BACKEND_ENV="${DIR}/<<BACKEND_ENV_PATH>>"
COMPOSE_BASE="${DIR}/<<COMPOSE_BASE>>"
# <<#IF HAS_IDP>>
COMPOSE_IDP="${DIR}/<<COMPOSE_IDP>>"
COMPOSE_IDP_OVERRIDE="${DIR}/<<COMPOSE_IDP_OVERRIDE>>"
CERTS_DIR="${DIR}/infra/certs"
CADDY_DIR="${DIR}/infra/caddy"
VITE_HTTPS_CONFIG="${DIR}/.vite.config.lan.ts"
# <<#END>>

# <<#IF HAS_IDP>>
# ---- pre-flight: detect destructive drift ----------------------------------
PREV_EXTERNAL=""
[[ -f "$STATE_FILE" ]] && PREV_EXTERNAL="$(grep -E '^EXTERNAL_FULL=' "$STATE_FILE" | cut -d= -f2- || true)"
HAS_VOLUME="$(docker volume ls --format '{{.Name}}' 2>/dev/null | grep -E '<<IDP_VOLUME_PATTERN>>' | head -1 || true)"

if $RESET; then
  log_warn "--reset: dropping IdP and volume…"
  docker compose -f "$COMPOSE_IDP" down -v 2>/dev/null || true
  PREV_EXTERNAL=""
elif [[ -n "$PREV_EXTERNAL" && "$PREV_EXTERNAL" != "$EXTERNAL_FULL" && -n "$HAS_VOLUME" ]]; then
  log_error "IdP was initialized with $PREV_EXTERNAL; switching to $EXTERNAL_FULL requires reset."
  log_error "Run: ./dev.sh --reset   (drops users/PATs/secrets persisted in the IdP volume)"
  exit 1
fi
# <<#END>>

# <<#IF HAS_TLS>>
# ---- TLS: mkcert + Caddy ---------------------------------------------------
MKCERT_CAROOT=""
if $TLS_MODE; then
  command -v mkcert >/dev/null 2>&1 || { log_error "mkcert not found — install: https://github.com/FiloSottile/mkcert (or run with --no-https; OIDC outside localhost will fail)"; exit 1; }
  MKCERT_CAROOT="$(mkcert -CAROOT)"
  [[ -f "${MKCERT_CAROOT}/rootCA.pem" ]] || { log_step "Installing mkcert root CA (may prompt for sudo)…"; mkcert -install; }

  mkdir -p "$CERTS_DIR" "$CADDY_DIR"
  CERT_FILE="${CERTS_DIR}/dev.pem"; KEY_FILE="${CERTS_DIR}/dev.key"
  CERT_NAMES_FILE="${CERTS_DIR}/.names"
  CURRENT_NAMES="${EXTERNAL_DOMAIN} ${HOST} localhost 127.0.0.1"
  PREV_NAMES="$(cat "$CERT_NAMES_FILE" 2>/dev/null || true)"
  if [[ ! -f "$CERT_FILE" || ! -f "$KEY_FILE" || "$PREV_NAMES" != "$CURRENT_NAMES" ]]; then
    log_step "Issuing mkcert leaf for: ${CURRENT_NAMES}"
    # shellcheck disable=SC2086
    mkcert -cert-file "$CERT_FILE" -key-file "$KEY_FILE" $CURRENT_NAMES
    echo "$CURRENT_NAMES" > "$CERT_NAMES_FILE"
  fi

  # Make the rootCA available for LAN clients to download from the SPA static dir
  cp "${MKCERT_CAROOT}/rootCA.pem" "${DIR}/<<PUBLIC_DIR>>/dev-rootCA.pem" 2>/dev/null || true

  cat > "${CADDY_DIR}/Caddyfile" <<EOF
{
  auto_https off
  admin off
}

${EXTERNAL_DOMAIN}:${WEB_PORT} { tls /certs/dev.pem /certs/dev.key
  reverse_proxy localhost:5173 }

${EXTERNAL_DOMAIN}:${API_PORT} { tls /certs/dev.pem /certs/dev.key
  reverse_proxy localhost:3000 }

${EXTERNAL_DOMAIN}:${IDP_PORT} { tls /certs/dev.pem /certs/dev.key
  reverse_proxy localhost:8080 }
EOF

  cat > "$VITE_HTTPS_CONFIG" <<'EOF'
// Generated — do not hand-edit. Wraps vite.config to allow LAN hosts.
import base from "./vite.config";
import { mergeConfig } from "vite";
export default mergeConfig(base, {
  server: {
    allowedHosts: true,
    hmr: { clientPort: 5443, protocol: "wss", host: process.env.DEV_SH_EXTERNAL ?? "localhost" },
  },
});
EOF
fi
# <<#END>>

# ---- envs ------------------------------------------------------------------
log_step "Synthesizing envs…"
patch_env_kv() {
  local file="$1" key="$2" value="$3"
  if grep -qE "^${key}=" "$file"; then sed -i "s|^${key}=.*|${key}=${value}|" "$file"
  else echo "${key}=${value}" >> "$file"; fi
}

# .env.local (frontend)
cat > "$ROOT_ENV_LOCAL" <<EOF
# Generated — do not hand-edit
VITE_API_BASE_URL=${API_BASE}/api
# <<#IF HAS_OIDC>>
VITE_OIDC_AUTHORITY=${ZITADEL_BASE}
VITE_OIDC_CLIENT_ID=
VITE_OIDC_REDIRECT_URI=${WEB_BASE}/auth/callback
VITE_OIDC_POST_LOGOUT_REDIRECT_URI=${WEB_BASE}/login
VITE_OIDC_SILENT_REDIRECT_URI=${WEB_BASE}/silent-renew
VITE_OIDC_SCOPE=openid profile email
# <<#END>>
EOF

# Backend env
# <<#IF HAS_OIDC>>
patch_env_kv "$BACKEND_ENV" "AUTH_ISSUER"   "${ZITADEL_BASE}"
patch_env_kv "$BACKEND_ENV" "AUTH_JWKS_URL" "${ZITADEL_BASE}/oauth/v2/keys"
# <<#END>>
patch_env_kv "$BACKEND_ENV" "CORS_ORIGINS" "${WEB_BASE}"
# Disable rate limit in dev — StrictMode + React Query refetches blow past 120/min easily.
patch_env_kv "$BACKEND_ENV" "RATE_LIMIT_PER_MINUTE" "0"

# <<#IF HAS_IDP>>
# Compose override for Zitadel external URL trio + Caddy service
{
  cat <<EOF
# Generated — do not hand-edit
services:
  zitadel-init:
    environment:
      ZITADEL_EXTERNALDOMAIN: ${EXTERNAL_DOMAIN}
      ZITADEL_EXTERNALPORT: ${IDP_PORT}
      ZITADEL_EXTERNALSECURE: $($TLS_MODE && echo true || echo false)
  zitadel:
    environment:
      ZITADEL_EXTERNALDOMAIN: ${EXTERNAL_DOMAIN}
      ZITADEL_EXTERNALPORT: ${IDP_PORT}
      ZITADEL_EXTERNALSECURE: $($TLS_MODE && echo true || echo false)
EOF
  if $TLS_MODE; then cat <<EOF
    command: >-
      start-from-init
      --masterkey \${ZITADEL_MASTERKEY:?required in infra/docker/.env}
      --tlsMode external

  caddy:
    image: caddy:2-alpine
    restart: unless-stopped
    network_mode: host
    depends_on: { zitadel: { condition: service_healthy } }
    volumes:
      - ${CADDY_DIR}/Caddyfile:/etc/caddy/Caddyfile:ro
      - ${CERTS_DIR}:/certs:ro
EOF
  fi
} > "$COMPOSE_IDP_OVERRIDE"
# <<#END>>

log_info "Envs synthesized"

# ---- containers ------------------------------------------------------------
log_step "Postgres up…"
docker compose -f "$COMPOSE_BASE" up -d postgres

log_step "Wait Postgres…"
for i in $(seq 1 30); do
  docker compose -f "$COMPOSE_BASE" exec -T postgres pg_isready -U <<DB_USER>> >/dev/null 2>&1 && { log_info "Postgres ready"; break; }
  sleep 1; [[ $i -eq 30 ]] && { log_error "Postgres not ready"; exit 1; }
done

# <<#IF HAS_IDP>>
log_step "IdP + sidecars up…"
docker compose -f "$COMPOSE_IDP" -f "$COMPOSE_IDP_OVERRIDE" up -d <<IDP_CORE_SERVICES>>
if $TLS_MODE; then docker compose -f "$COMPOSE_IDP" -f "$COMPOSE_IDP_OVERRIDE" up -d caddy; fi

log_step "Wait IdP…"
CURL_OPTS=(); $TLS_MODE && CURL_OPTS+=(--cacert "${MKCERT_CAROOT}/rootCA.pem")
for i in $(seq 1 60); do
  curl -fsS "${CURL_OPTS[@]}" "${ZITADEL_BASE}<<IDP_HEALTH_PATH>>" >/dev/null 2>&1 && { log_info "IdP ready"; break; }
  sleep 2; [[ $i -eq 60 ]] && { log_error "IdP not ready at ${ZITADEL_BASE}"; exit 1; }
done
# <<#END>>

# <<#IF HAS_BOOTSTRAP>>
# ---- bootstrap (idempotent) ------------------------------------------------
BOOTSTRAP_OUT="${DIR}/<<BOOTSTRAP_OUTPUT_PATH>>"
SKIP_BOOTSTRAP=false
if [[ -n "${PREV_EXTERNAL:-}" && "$PREV_EXTERNAL" == "$EXTERNAL_FULL" && -f "$BOOTSTRAP_OUT" ]]; then
  SKIP_BOOTSTRAP=true
fi
if $SKIP_BOOTSTRAP; then
  log_step "Bootstrap — skipping (already up to date for ${EXTERNAL_FULL})"
else
  log_step "Bootstrap…"
  BOOTSTRAP_ENV=()
  $TLS_MODE && BOOTSTRAP_ENV+=("NODE_EXTRA_CA_CERTS=${MKCERT_CAROOT}/rootCA.pem")
  env "${BOOTSTRAP_ENV[@]}" \
    <<BOOTSTRAP_ENV_VARS>> \
    <<BOOTSTRAP_COMMAND>>
  test -s "$BOOTSTRAP_OUT" || { log_error "Bootstrap did not produce $BOOTSTRAP_OUT"; exit 1; }
fi

# Re-derive volatile IDs from bootstrap output
if [[ -f "$BOOTSTRAP_OUT" ]]; then
  CLIENT_ID="$(grep -oE '"clientId"[[:space:]]*:[[:space:]]*"[^"]+"' "$BOOTSTRAP_OUT" | head -1 | sed -E 's/.*"([^"]+)"$/\1/')"
  PROJECT_ID="$(grep -oE '"projectId"[[:space:]]*:[[:space:]]*"[^"]+"' "$BOOTSTRAP_OUT" | head -1 | sed -E 's/.*"([^"]+)"$/\1/')"
  [[ -n "$CLIENT_ID"  ]] && { sed -i "s|^VITE_OIDC_CLIENT_ID=.*|VITE_OIDC_CLIENT_ID=${CLIENT_ID}|" "$ROOT_ENV_LOCAL"; log_info "VITE_OIDC_CLIENT_ID=${CLIENT_ID}"; }
  [[ -n "$PROJECT_ID" ]] && { patch_env_kv "$BACKEND_ENV" "AUTH_AUDIENCE" "$PROJECT_ID"; log_info "AUTH_AUDIENCE=${PROJECT_ID}"; }
fi
# <<#END>>

# Persist state for next run
{
  echo "EXTERNAL_FULL=${EXTERNAL_FULL:-}"
  echo "HOST=${HOST}"
  echo "TLS=${TLS_MODE}"
} > "$STATE_FILE"

# ---- port reclaim ----------------------------------------------------------
kill_port() {
  local port="$1" pids=""
  if command -v fuser >/dev/null 2>&1; then
    pids="$(fuser "${port}/tcp" 2>/dev/null | tr -s ' ' '\n' | grep -E '^[0-9]+$' | sort -u || true)"
  fi
  if [[ -z "$pids" ]] && command -v lsof >/dev/null 2>&1; then
    pids="$(lsof -tiTCP:"$port" -sTCP:LISTEN 2>/dev/null || true)"
  fi
  [[ -z "$pids" ]] && pids="$(ss -tlnp "sport = :$port" 2>/dev/null | grep -oP 'pid=\K[0-9]+' | sort -u || true)"
  for pid in $pids; do
    log_warn "Port $port held by PID $pid — killing"
    kill "$pid" 2>/dev/null || true; sleep 1
    kill -0 "$pid" 2>/dev/null && kill -9 "$pid" 2>/dev/null || true
  done
}
log_step "Free ports 3000 / 5173…"
kill_port 3000; kill_port 5173

# ---- dev servers + cleanup -------------------------------------------------
PIDS=()
cleanup() {
  echo ""
  log_warn "Stopping dev servers…"
  for pid in "${PIDS[@]:-}"; do [[ -z "$pid" ]] && continue; kill -- "-$pid" 2>/dev/null || kill "$pid" 2>/dev/null || true; done
  sleep 1
  for pid in "${PIDS[@]:-}"; do [[ -z "$pid" ]] && continue; kill -0 "$pid" 2>/dev/null && kill -9 "$pid" 2>/dev/null || true; done
  if $DOWN_ON_EXIT; then
    log_warn "--down: tearing down containers…"
    # <<#IF HAS_IDP>>
    docker compose -f "$COMPOSE_IDP" -f "$COMPOSE_IDP_OVERRIDE" down 2>/dev/null || true
    # <<#END>>
    docker compose -f "$COMPOSE_BASE" down 2>/dev/null || true
  fi
  log_info "Stopped."
}
trap cleanup EXIT SIGINT SIGTERM

log_step "Backend up (:3000 internal)…"
BACKEND_EXPORTS=()
$TLS_MODE && BACKEND_EXPORTS+=("NODE_EXTRA_CA_CERTS=${MKCERT_CAROOT}/rootCA.pem")
PREFIX_API="${GREEN}[BACKEND]${NC}"
( cd "${DIR}/<<BACKEND_DIR>>"; env "${BACKEND_EXPORTS[@]}" setsid <<BACKEND_DEV_CMD>> 2>&1 | sed -u "s/^/$(echo -e "$PREFIX_API") /" ) &
PIDS+=($!)

log_step "Frontend up (:5173 internal)…"
PREFIX_WEB="${BLUE}[WEB]${NC}"
VITE_CONFIG_ARG=()
$TLS_MODE && VITE_CONFIG_ARG+=(--config "$VITE_HTTPS_CONFIG")
( cd "$DIR"; DEV_SH_EXTERNAL="${EXTERNAL_DOMAIN}" setsid <<FRONTEND_DEV_CMD>> -- "${VITE_CONFIG_ARG[@]}" --host 0.0.0.0 --port 5173 --strictPort 2>&1 | sed -u "s/^/$(echo -e "$PREFIX_WEB") /" ) &
PIDS+=($!)

# ---- summary ---------------------------------------------------------------
sleep 2
echo ""
echo -e "${GREEN}=============================================${NC}"
echo -e "${GREEN}  <<PROJECT_NAME>> — dev mode${NC}"
echo -e "${GREEN}=============================================${NC}"
echo ""
echo -e "  ${BLUE}Frontend${NC}  → ${WEB_BASE}"
echo -e "  ${GREEN}Backend${NC}   → ${API_BASE}/api"
# <<#IF HAS_IDP>>
echo -e "  ${MAGENTA}IdP${NC}       → ${ZITADEL_BASE}"
# <<#END>>
echo ""
$LAN_MODE && echo -e "  ${YELLOW}LAN sharing${NC} — clients open ${WEB_BASE}"
# <<#IF HAS_TLS>>
if $TLS_MODE; then
  echo -e "  ${YELLOW}HTTPS via mkcert${NC} — clients must trust the local rootCA:"
  echo -e "    on dev host: ${MKCERT_CAROOT}/rootCA.pem"
  echo -e "    download:    ${WEB_BASE}/dev-rootCA.pem"
fi
# <<#END>>
echo -e "  Ctrl+C stops dev servers (containers persist; --down tears down)."
echo -e "${GREEN}=============================================${NC}"
echo ""
wait
